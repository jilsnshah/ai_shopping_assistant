# Environment Configuration for AI Shopping Assistant

# ==================== FIREBASE REALTIME DATABASE ====================
# Firebase is used for all data persistence (buyer/seller data + conversation history)
# Download your service account key from Firebase Console and save as firebase-credentials.json

FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com/


# ==================== GEMINI AI API ====================
# Get your API key from: https://aistudio.google.com/app/apikey

GEMINI_API_KEY=your_gemini_api_key_here


# ==================== WHATSAPP BUSINESS API ====================
# WhatsApp Business API credentials for sending/receiving messages

WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_BUSINESS_ACCOUNT_ID=your_business_account_id
WHATSAPP_ACCESS_TOKEN=your_whatsapp_access_token_here
VERIFY_TOKEN=your_custom_webhook_verify_token


# ==================== RAZORPAY ====================
# Get credentials from: https://dashboard.razorpay.com/app/keys

RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret


# ==================== APPLICATION SETTINGS ====================

FLASK_ENV=development
FLASK_DEBUG=true
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
